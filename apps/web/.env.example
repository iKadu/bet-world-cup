
# PostgreSQL connection string (local, or a cloud provider like Neon/Supabase in production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Allowed origin for CORS — usually the app's own URL
CORS_ORIGIN=http://localhost:3001

# Better Auth secret — generate a random value, 32+ characters
# e.g. openssl rand -hex 32  (or: bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=

# Public URL of the app (usually the same as CORS_ORIGIN)
BETTER_AUTH_URL=http://localhost:3001

# Free API key from football-data.org — sign up at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Shared secret used to authorize calls to /api/sync — generate 16+ random characters
CRON_SECRET=

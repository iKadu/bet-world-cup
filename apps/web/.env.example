
# Connection string do PostgreSQL (local ou um provedor na nuvem como Neon/Supabase em produção)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Origem permitida para CORS — normalmente a própria URL do app
CORS_ORIGIN=http://localhost:3001

# Segredo do Better Auth — gere um valor aleatório de 32+ caracteres
# ex: openssl rand -hex 32  (ou: bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=

# URL pública do app (a mesma do CORS_ORIGIN na maioria dos casos)
BETTER_AUTH_URL=http://localhost:3001

# Chave gratuita da football-data.org — cadastre-se em https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Segredo compartilhado para autorizar chamadas à rota /api/sync — gere com 16+ caracteres aleatórios
CRON_SECRET=
